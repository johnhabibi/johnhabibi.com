# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key

/public/packs
/public/packs-test
/node_modules
/yarn-error.log
yarn-debug.log*
.yarn-integrity

# Ignore .env files as they are personal
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore database configuration
/config/database.yml.local

# Ignore application configuration
/config/application.yml

# Ignore coverage reports
/coverage/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Ruby
*.gem
*.rbc
/.config
/InstalledFiles
/pkg/
/spec/reports/
/spec/examples.txt
/test/tmp/
/test/version_tmp/
/tmp/

# RDoc documentation
/doc/
/rdoc/

# Yard documentation
/.yardoc/
/_yardoc/
/doc/
/rdoc/

# Bundler
.bundle/
vendor/bundle

# Secrets
/config/secrets.yml
/config/credentials.yml.enc

# Database
*.sqlite3
*.sqlite3-*

# Redis
dump.rdb

# Ignore built assets
/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore Tailwind CSS builds
/app/assets/builds/

# Ignore node modules if using any JS preprocessor
/node_modules

# Ignore yarn files
yarn-debug.log*
yarn-error.log

# Ignore package-lock.json if using yarn
package-lock.json

# Ignore personal notes
notes.md
TODO.md

# Ignore backup files
*.backup
*.bak

# Ignore terraform files if using infrastructure as code
*.tfstate
*.tfstate.*
.terraform/

# Ignore local environment setup scripts
setup.sh
start.sh

# Ignore Rails tmp files
/tmp/cache/
/tmp/sessions/
/tmp/sockets/

# Ignore test coverage
/coverage/

# Ignore Spring files
/spring/*.pid

# Ignore bootsnap cache
/tmp/bootsnap*

# Ignore credentials
/config/credentials/
