<section class="py-20 px-6">
  <div class="max-w-2xl mx-auto">
    <div class="text-center mb-12">
      <h1 class="text-4xl lg:text-5xl font-light mb-4" style="font-family: 'Crimson Text', serif;">
        Get In Touch
      </h1>
      <p class="text-lg text-gray-300" style="font-family: 'Inter', sans-serif;">
        I'd love to hear from you. Send me a message and I'll get back to you soon.
      </p>
    </div>

    <%= form_with model: @contact, url: contacts_path, local: true, class: "space-y-6" do |form| %>
      <% if @contact.errors.any? %>
        <div class="bg-red-800 text-red-100 p-4 rounded-lg">
          <h4 class="font-medium mb-2">Please fix the following errors:</h4>
          <ul class="list-disc list-inside space-y-1">
            <% @contact.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= form.label :name, class: "block text-sm font-medium mb-2 tracking-wide uppercase" %>
          <%= form.text_field :name,
              class: "w-full px-4 py-3 bg-gray-800 border border-gray-600 text-white placeholder-gray-400 focus:border-gray-400 focus:outline-none transition-colors",
              placeholder: "Your name" %>
        </div>

        <div>
          <%= form.label :email, class: "block text-sm font-medium mb-2 tracking-wide uppercase" %>
          <%= form.email_field :email,
              class: "w-full px-4 py-3 bg-gray-800 border border-gray-600 text-white placeholder-gray-400 focus:border-gray-400 focus:outline-none transition-colors",
              placeholder: "your@email.com" %>
        </div>
      </div>

      <div>
        <%= form.label :subject, class: "block text-sm font-medium mb-2 tracking-wide uppercase" %>
        <%= form.text_field :subject,
            class: "w-full px-4 py-3 bg-gray-800 border border-gray-600 text-white placeholder-gray-400 focus:border-gray-400 focus:outline-none transition-colors",
            placeholder: "What's this about?" %>
      </div>

      <div>
        <%= form.label :message, class: "block text-sm font-medium mb-2 tracking-wide uppercase" %>
        <%= form.text_area :message,
            rows: 6,
            class: "w-full px-4 py-3 bg-gray-800 border border-gray-600 text-white placeholder-gray-400 focus:border-gray-400 focus:outline-none transition-colors resize-vertical",
            placeholder: "Your message..." %>
      </div>

      <div class="text-center pt-4">
        <%= form.submit "Send Message",
            class: "px-8 py-3 border border-white text-white hover:bg-white hover:text-gray-900 transition-all duration-300 tracking-wider text-sm uppercase cursor-pointer" %>
      </div>
    <% end %>
  </div>
</section>
