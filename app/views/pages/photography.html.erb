<section class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h1 class="text-4xl lg:text-5xl font-light mb-4" style="font-family: 'Crimson Text', serif;">
        Photography
      </h1>
      <p class="text-lg text-gray-300 mb-8" style="font-family: 'Inter', sans-serif;">
        Visual stories and captured moments
      </p>

      <!-- View Full Gallery Button -->
      <div class="mb-12">
        <%= link_to photos_path,
            class: "inline-flex items-center px-8 py-3 bg-white text-gray-900 hover:bg-gray-100 transition-colors duration-300 text-sm tracking-wide uppercase font-medium" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          View Full Gallery
        <% end %>
      </div>
    </div>

    <!-- Category Preview Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">

      <!-- Photography Category 1 -->
      <%= link_to photos_path(category: 'Landscapes'), class: "block" do %>
        <div class="aspect-square bg-gray-800 hover:bg-gray-700 transition-colors duration-300 cursor-pointer group">
          <div class="w-full h-full flex items-center justify-center">
            <div class="text-center text-gray-500 group-hover:text-gray-400">
              <svg class="w-16 h-16 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <p class="text-sm">Landscapes</p>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Photo 2 -->
      <div class="aspect-square bg-gray-800 hover:bg-gray-700 transition-colors duration-300 cursor-pointer group">
        <div class="w-full h-full flex items-center justify-center">
          <div class="text-center text-gray-500 group-hover:text-gray-400">
            <svg class="w-16 h-16 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <p class="text-sm">Portraits</p>
          </div>
        </div>
      </div>

      <!-- Photo 3 -->
      <div class="aspect-square bg-gray-800 hover:bg-gray-700 transition-colors duration-300 cursor-pointer group">
        <div class="w-full h-full flex items-center justify-center">
          <div class="text-center text-gray-500 group-hover:text-gray-400">
            <svg class="w-16 h-16 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <p class="text-sm">Nature</p>
          </div>
        </div>
      </div>

      <!-- Photo 4 -->
      <div class="aspect-square bg-gray-800 hover:bg-gray-700 transition-colors duration-300 cursor-pointer group">
        <div class="w-full h-full flex items-center justify-center">
          <div class="text-center text-gray-500 group-hover:text-gray-400">
            <svg class="w-16 h-16 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <p class="text-sm">Street Photography</p>
          </div>
        </div>
      </div>

      <!-- Photo 5 -->
      <div class="aspect-square bg-gray-800 hover:bg-gray-700 transition-colors duration-300 cursor-pointer group">
        <div class="w-full h-full flex items-center justify-center">
          <div class="text-center text-gray-500 group-hover:text-gray-400">
            <svg class="w-16 h-16 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <p class="text-sm">Architecture</p>
          </div>
        </div>
      </div>

      <!-- Photo 6 -->
      <div class="aspect-square bg-gray-800 hover:bg-gray-700 transition-colors duration-300 cursor-pointer group">
        <div class="w-full h-full flex items-center justify-center">
          <div class="text-center text-gray-500 group-hover:text-gray-400">
            <svg class="w-16 h-16 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <p class="text-sm">Abstract</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Statement -->
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-gray-300 leading-relaxed" style="font-family: 'Inter', sans-serif;">
        Photography allows me to capture the fleeting moments that reveal deeper truths about our world.
        Through light, shadow, and composition, I seek to create images that resonate on both emotional
        and intellectual levels, inviting viewers to see familiar spaces with fresh perspective.
      </p>
    </div>
  </div>
</section>
