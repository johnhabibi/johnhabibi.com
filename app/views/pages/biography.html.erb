<section class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-20">
      <h1 class="text-4xl lg:text-5xl xl:text-6xl font-light mb-6" style="font-family: 'Crimson Text', serif;">
        Biography
      </h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
      <!-- Profile Image -->
      <div class="lg:col-span-1">
        <div class="w-full aspect-square rounded-lg overflow-hidden shadow-xl">
          <%= image_tag "john-habibi-bio.jpg",
              alt: "John Habibi",
              class: "w-full h-full object-cover" %>
        </div>
      </div>

      <!-- Biography Content -->
      <div class="lg:col-span-2 space-y-10" style="font-family: 'Inter', sans-serif;">

        <div class="space-y-6">
          <h2 class="text-2xl lg:text-3xl font-medium text-gray-200">About John</h2>
          <p class="text-gray-300 leading-relaxed text-lg">
            John Habibi is a multidisciplinary creator working at the intersection of technology, art, and human connection.
            Through his diverse body of work spanning writing, photography, music, and software development, he explores
            the ways technology can enhance rather than replace authentic human experiences.
          </p>
        </div>

        <div class="space-y-6">
          <h3 class="text-xl lg:text-2xl font-medium text-gray-200">Writing</h3>
          <p class="text-gray-300 leading-relaxed">
            As a writer, John shares insights on technology, creativity, and the evolving relationship between
            humans and digital tools. His writing combines technical depth with philosophical reflection, making complex
            topics accessible to a broad audience.
          </p>
        </div>        <div class="space-y-6">
          <h3 class="text-xl lg:text-2xl font-medium text-gray-200">Photography</h3>
          <p class="text-gray-300 leading-relaxed">
            John's photography captures the beauty in everyday moments and the poetry of urban life. His work focuses on
            the interplay between light, shadow, and human emotion, creating visual narratives that resonate on both
            personal and universal levels.
          </p>
        </div>

        <div class="space-y-6">
          <h3 class="text-xl lg:text-2xl font-medium text-gray-200">Music</h3>
          <p class="text-gray-300 leading-relaxed">
            Through composition and performance, John creates atmospheric soundscapes that blend electronic and acoustic
            elements. His music serves as a bridge between the digital and organic worlds, exploring themes of memory,
            place, and transformation.
          </p>
        </div>

        <div class="space-y-6">
          <h3 class="text-xl lg:text-2xl font-medium text-gray-200">Development</h3>
          <p class="text-gray-300 leading-relaxed">
            As an app developer, John builds thoughtful digital solutions that prioritize user experience and meaningful
            interaction. His applications reflect his belief that technology should serve human needs rather than dominate them.
          </p>
        </div>

        <!-- Download Biography Button -->
        <div class="pt-10">
          <%= link_to download_biography_path,
              class: "inline-block px-8 py-4 border border-white text-white hover:bg-white hover:text-gray-900 transition-all duration-300 tracking-wider text-sm uppercase font-medium" do %>
            Download Full Biography
            <svg class="inline-block w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
