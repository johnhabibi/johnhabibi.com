<!-- Admin Photos Management -->
<div class="pt-24 pb-20 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-light text-white" style="font-family: 'Crimson Text', serif;">
        Photo Management
      </h1>
      <div class="flex space-x-3">
        <%= link_to bulk_upload_form_admin_photos_path,
            class: "inline-flex items-center px-6 py-2 bg-green-600 hover:bg-green-700 text-white rounded transition-colors" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 12l2 2 4-4"></path>
          </svg>
          Bulk Upload
        <% end %>
        <%= link_to new_admin_photo_path,
            class: "inline-flex items-center px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded transition-colors" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          Upload Single Photo
        <% end %>
      </div>
    </div>

    <% if @photos.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <% @photos.each do |photo| %>
          <div class="bg-gray-800 rounded-lg overflow-hidden">
            <div class="aspect-square overflow-hidden">
              <%= image_tag photo.thumbnail,
                  alt: photo.title,
                  class: "w-full h-full object-cover" %>
            </div>

            <div class="p-4">
              <h3 class="font-medium text-white truncate mb-1"><%= photo.title %></h3>
              <% if photo.category.present? %>
                <p class="text-sm text-gray-400 mb-3"><%= photo.category %></p>
              <% end %>

              <div class="flex justify-between items-center">
                <div class="flex space-x-2">
                  <%= link_to edit_admin_photo_path(photo),
                      class: "text-blue-400 hover:text-blue-300 text-sm" do %>
                    Edit
                  <% end %>
                  <%= link_to photo_path(photo),
                      class: "text-gray-400 hover:text-white text-sm" do %>
                    View
                  <% end %>
                </div>

                <%= link_to admin_photo_path(photo),
                    method: :delete,
                    data: { confirm: "Are you sure you want to delete this photo?" },
                    class: "text-red-400 hover:text-red-300 text-sm" do %>
                  Delete
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-20">
        <div class="text-gray-400 text-lg mb-6" style="font-family: 'Inter', sans-serif;">
          No photos uploaded yet.
        </div>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <%= link_to bulk_upload_form_admin_photos_path,
              class: "inline-flex items-center px-6 py-3 bg-green-600 hover:bg-green-700 text-white rounded transition-colors" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 12l2 2 4-4"></path>
            </svg>
            Upload Multiple Photos
          <% end %>
          <%= link_to new_admin_photo_path,
              class: "inline-flex items-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded transition-colors" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Upload Single Photo
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
