<!-- Admin Photo Upload -->
<div class="pt-24 pb-20 px-6">
  <div class="max-w-2xl mx-auto">
    <div class="mb-8">
      <%= link_to admin_photos_path, class: "inline-flex items-center text-gray-400 hover:text-white transition-colors" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Photos
      <% end %>
    </div>

    <h1 class="text-3xl font-light text-white mb-8" style="font-family: 'Crimson Text', serif;">
      Upload New Photo
    </h1>

    <%= form_with model: [:admin, @photo], local: true, multipart: true, class: "space-y-6" do |form| %>
      <% if @photo.errors.any? %>
        <div class="bg-red-900/20 border border-red-700 text-red-400 px-4 py-3 rounded">
          <h4 class="font-medium mb-2">Please fix the following errors:</h4>
          <ul class="list-disc list-inside space-y-1">
            <% @photo.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :image, "Photo", class: "block text-sm font-medium text-gray-300 mb-2" %>
        <%= form.file_field :image,
            accept: "image/*",
            class: "w-full px-3 py-2 bg-gray-800 border border-gray-700 text-white rounded focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      </div>

      <div>
        <%= form.label :title, class: "block text-sm font-medium text-gray-300 mb-2" %>
        <%= form.text_field :title,
            class: "w-full px-3 py-2 bg-gray-800 border border-gray-700 text-white rounded focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      </div>

      <div>
        <%= form.label :category, class: "block text-sm font-medium text-gray-300 mb-2" %>
        <%= form.select :category,
            options_for_select([['Select Category', '']] + Photo::CATEGORIES.map { |cat| [cat, cat] }, @photo.category),
            {},
            class: "w-full px-3 py-2 bg-gray-800 border border-gray-700 text-white rounded focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      </div>

      <div>
        <%= form.label :description, class: "block text-sm font-medium text-gray-300 mb-2" %>
        <%= form.text_area :description,
            rows: 4,
            class: "w-full px-3 py-2 bg-gray-800 border border-gray-700 text-white rounded focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      </div>

      <div>
        <%= form.label :taken_at, "Date Taken", class: "block text-sm font-medium text-gray-300 mb-2" %>
        <%= form.date_field :taken_at,
            class: "w-full px-3 py-2 bg-gray-800 border border-gray-700 text-white rounded focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      </div>

      <div class="flex justify-end space-x-4">
        <%= link_to "Cancel", admin_photos_path,
            class: "px-6 py-2 text-gray-400 hover:text-white transition-colors" %>
        <%= form.submit "Upload Photo",
            class: "px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
