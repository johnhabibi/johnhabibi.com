<!-- Hero Section -->
<section class="min-h-screen flex items-center justify-center">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left side - Text content -->
      <div class="space-y-8">
        <div class="space-y-6">
          <h1 class="text-5xl lg:text-6xl xl:text-7xl font-light tracking-wide leading-tight" style="font-family: 'Crimson Text', serif;">
            JOHN HABIBI
          </h1>

          <div class="space-y-6 text-lg lg:text-xl text-gray-300" style="font-family: 'Inter', sans-serif;">
            <p class="italic text-xl lg:text-2xl">Writer & Creator</p>

            <div class="space-y-4">
              <div>
                <p class="font-medium tracking-wide">WRITER</p>
                <p class="text-base lg:text-lg italic text-gray-400">Exploring technology, creativity, and human connection</p>
              </div>

              <div>
                <p class="font-medium tracking-wide">PHOTOGRAPHER</p>
                <p class="text-base lg:text-lg italic text-gray-400">Capturing moments and stories</p>
              </div>

              <div>
                <p class="font-medium tracking-wide">MUSICIAN</p>
                <p class="text-base lg:text-lg italic text-gray-400">Creating sounds and experiences</p>
              </div>

              <div>
                <p class="font-medium tracking-wide">APP DEVELOPER</p>
                <p class="text-base lg:text-lg italic text-gray-400">Building digital solutions</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Download Biography Button -->
        <div class="pt-6">
          <%= link_to download_biography_path,
              class: "inline-block px-8 py-4 border border-white text-white hover:bg-white hover:text-gray-900 transition-all duration-300 tracking-wider text-sm uppercase font-medium" do %>
            Download Biography
            <svg class="inline-block w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          <% end %>
        </div>
      </div>

      <!-- Right side - Profile image -->
      <div class="flex items-center justify-center lg:justify-end">
        <div class="w-80 h-80 lg:w-96 lg:h-96 xl:w-[450px] xl:h-[450px] rounded-lg overflow-hidden shadow-2xl">
          <%= image_tag "john-habibi-bio.jpg",
              alt: "John Habibi",
              class: "w-full h-full object-cover" %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Quick Navigation Section -->
<section class="py-24 bg-gray-900/50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">

      <%= link_to writing_path, class: "group block p-8 border border-gray-700 hover:border-gray-500 hover:bg-gray-800/50 transition-all duration-300" do %>
        <div class="text-center">
          <div class="mb-6">
            <svg class="w-10 h-10 mx-auto text-gray-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-medium mb-3 tracking-wide">WRITING</h3>
          <p class="text-sm text-gray-400">Read my latest thoughts</p>
        </div>
      <% end %>

      <%= link_to photography_path, class: "group block p-8 border border-gray-700 hover:border-gray-500 hover:bg-gray-800/50 transition-all duration-300" do %>
        <div class="text-center">
          <div class="mb-6">
            <svg class="w-10 h-10 mx-auto text-gray-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-medium mb-3 tracking-wide">PHOTOGRAPHY</h3>
          <p class="text-sm text-gray-400">Visual stories and moments</p>
        </div>
      <% end %>

      <%= link_to music_path, class: "group block p-8 border border-gray-700 hover:border-gray-500 hover:bg-gray-800/50 transition-all duration-300" do %>
        <div class="text-center">
          <div class="mb-6">
            <svg class="w-10 h-10 mx-auto text-gray-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path>
            </svg>
          </div>
          <h3 class="text-lg font-medium mb-3 tracking-wide">MUSIC</h3>
          <p class="text-sm text-gray-400">Listen to my compositions</p>
        </div>
      <% end %>

      <%= link_to development_path, class: "group block p-8 border border-gray-700 hover:border-gray-500 hover:bg-gray-800/50 transition-all duration-300" do %>
        <div class="text-center">
          <div class="mb-6">
            <svg class="w-10 h-10 mx-auto text-gray-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
          </div>
          <h3 class="text-lg font-medium mb-3 tracking-wide">DEVELOPMENT</h3>
          <p class="text-sm text-gray-400">Apps and digital projects</p>
        </div>
      <% end %>

    </div>
  </div>
</section>
