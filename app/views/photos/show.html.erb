<!-- Photo Detail View -->
<div class="pt-24 pb-20 px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Back to Gallery -->
    <div class="mb-8">
      <%= link_to photos_path, class: "inline-flex items-center text-gray-400 hover:text-white transition-colors" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Gallery
      <% end %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Photo -->
      <div class="lg:col-span-2">
        <div class="relative group">
          <%= image_tag @photo.large,
              alt: @photo.title,
              class: "w-full h-auto rounded-lg shadow-2xl cursor-zoom-in",
              id: "main-photo" %>

          <!-- Navigation arrows -->
          <% if @prev_photo %>
            <%= link_to photo_path(@prev_photo),
                class: "absolute left-4 top-1/2 transform -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white p-3 rounded-full opacity-0 group-hover:opacity-100 transition-all duration-300" do %>
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
              </svg>
            <% end %>
          <% end %>

          <% if @next_photo %>
            <%= link_to photo_path(@next_photo),
                class: "absolute right-4 top-1/2 transform -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white p-3 rounded-full opacity-0 group-hover:opacity-100 transition-all duration-300" do %>
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Photo Details -->
      <div class="space-y-8" style="font-family: 'Inter', sans-serif;">
        <div>
          <h1 class="text-3xl font-light text-white mb-4" style="font-family: 'Crimson Text', serif;">
            <%= @photo.title %>
          </h1>

          <% if @photo.category.present? %>
            <div class="inline-block px-3 py-1 bg-gray-800 text-gray-300 text-sm rounded-full mb-6">
              <%= @photo.category %>
            </div>
          <% end %>
        </div>

        <% if @photo.description.present? %>
          <div>
            <h3 class="text-lg font-medium text-white mb-3">Description</h3>
            <p class="text-gray-300 leading-relaxed">
              <%= simple_format(@photo.description) %>
            </p>
          </div>
        <% end %>

        <% if @photo.taken_at.present? %>
          <div>
            <h3 class="text-lg font-medium text-white mb-3">Date Taken</h3>
            <p class="text-gray-300">
              <%= @photo.taken_at.strftime("%B %d, %Y") %>
            </p>
          </div>
        <% end %>

        <!-- Download/Share options -->
        <div class="pt-6 border-t border-gray-700">
          <h3 class="text-lg font-medium text-white mb-4">Actions</h3>
          <div class="space-y-3">
            <%= link_to rails_blob_path(@photo.image, disposition: "attachment"),
                class: "inline-flex items-center text-gray-400 hover:text-white transition-colors" do %>
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              Download Full Resolution
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Lightbox Modal -->
<div id="lightbox" class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center p-4">
  <div class="relative max-w-full max-h-full">
    <img id="lightbox-image" src="" alt="" class="max-w-full max-h-full object-contain">
    <button id="close-lightbox" class="absolute top-4 right-4 text-white hover:text-gray-300 text-4xl">&times;</button>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const mainPhoto = document.getElementById('main-photo');
    const lightbox = document.getElementById('lightbox');
    const lightboxImage = document.getElementById('lightbox-image');
    const closeLightbox = document.getElementById('close-lightbox');

    // Open lightbox
    mainPhoto.addEventListener('click', function() {
      lightboxImage.src = '<%= url_for(@photo.full_size) %>';
      lightboxImage.alt = '<%= @photo.title %>';
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
    });

    // Close lightbox
    function closeLightboxModal() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = 'auto';
    }

    closeLightbox.addEventListener('click', closeLightboxModal);
    lightbox.addEventListener('click', function(e) {
      if (e.target === lightbox) {
        closeLightboxModal();
      }
    });

    // Keyboard navigation
    document.addEventListener('keydown', function(e) {
      if (lightbox.classList.contains('flex')) {
        if (e.key === 'Escape') {
          closeLightboxModal();
        }
      }
    });
  });
</script>
